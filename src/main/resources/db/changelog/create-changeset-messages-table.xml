<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet id="create_table_messages" author="mustafa">
        <createTable tableName="messages">
            <column autoIncrement="true" name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="chat_id" type="bigserial">
                <constraints foreignKeyName="message_chat_id" references="chats(id)"/>
            </column>
            <column name="user_id" type="bigserial">
                <constraints foreignKeyName="message_user_id" references="users(id)"/>
            </column>
            <column name="text" type="varchar">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>